# URL der Website, z. B. https://punktlandung.example.de
NEXT_PUBLIC_APP_URL=

# Optionaler Passwortschutz fuer Testbetrieb:
APP_ACCESS_PASSWORD=
APP_TEST_ACCESS_PASSWORD=

# Nur fuer statische Netcup-Webhosting-Builds:
# true = Bilder direkt laden, ohne /api/image Proxy
NEXT_PUBLIC_DISABLE_IMAGE_PROXY=false

# AdSense-ready Vorbereitung:
# Erst aktivieren, wenn Consent/CMP und echte AdSense-Slots final eingerichtet sind.
NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADS_REQUIRE_CONSENT=true
NEXT_PUBLIC_ADSENSE_TEST_MODE=true
NEXT_PUBLIC_ADSENSE_SLOT_HOME_LEFT_RAIL=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_RIGHT_RAIL=
NEXT_PUBLIC_ADSENSE_SLOT_LOBBY_LEFT_RAIL=
NEXT_PUBLIC_ADSENSE_SLOT_LOBBY_RIGHT_RAIL=
NEXT_PUBLIC_ADSENSE_SLOT_GAME_BOTTOM_LEFT=
