{
  "name": "punktlandung",
  "version": "1.0.0",
  "private": true,
  "description": "Punktlandung - kostenloses Geo-Quiz-Partyspiel mit Next.js und Leaflet.",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:full": "node scripts/dev.mjs",
    "next": "next dev -H 0.0.0.0 -p 3000",
    "ws": "tsx server/index.ts",
    "share:proxy": "tsx server/share-proxy.ts",
    "build": "next build",
    "build:static": "cross-env STATIC_EXPORT=true NEXT_PUBLIC_DISABLE_IMAGE_PROXY=true next build",
    "start": "next start -H localhost -p 3000",
    "catalog:generate": "node scripts/generate-wikimedia-catalog.mjs",
    "boundaries:generate": "node scripts/generate-location-boundaries.mjs",
    "boundaries:fetch": "node scripts/generate-location-boundaries.mjs --fetch-osm",
    "check:responsive": "node scripts/responsive-check.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/node": "^20.17.12",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.20",
    "leaflet": "^1.9.4",
    "next": "^14.2.23",
    "postcss": "^8.4.49",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "cross-env": "^7.0.3",
    "ngrok": "^5.0.0-beta.2"
  }
}
